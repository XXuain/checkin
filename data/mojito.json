{
    "meta": {
        "title": "鮮果氣泡飲",
        "sugar_ref": "data/sugar.json",
        "note": [
            "果肉要尖尖一滿匙，不可以平匙",
            "非現場等候的客人，等人到再打氣泡水跟冰塊，確保品質",
            "加購加料量到【150ml】，料少量到【100ml】",
            "加料 -5糖。因為料會佔據紙杯容量，氣泡水會減少，因此糖量也要減少不然會太甜不耐喝",
            "加料 1分糖分算法：(不要太甜 - 5) / 3",
            "加料 2分糖分算法：(不要太甜 - 5) / 3 x 2"
        ]
    },
    "shared_steps": {
        "ice_line": "紙杯加冰塊到會字，約16顆冰塊。",
        "material_in_cup": "白蔗糖、原汁入紙杯",
        "soda_shake": "加一半氣泡水，攪拌均勻。"
    },
    "sugar_calculation": {
        "1fen": "(less_sweet - 5) / 3",
        "2fen": "((less_sweet - 5) / 3) x 2",
        "less_sweet": "less_sweet - 5",
        "golden": "golden - 5"
    },
    "sugar_with_add_on": {
        "std-1-2-5-10": "add-0-0-0-5",
        "std-5-10-15-20": "add-3-6-10-15",
        "std-10-20-30-40": "add-8-16-25-35",
        "std-13-26-40-50": "add-11-23-35-45"
    },
